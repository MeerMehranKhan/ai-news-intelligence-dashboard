# ============================================================
# AI News Intelligence Dashboard — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you want.
# All keys are OPTIONAL — the app runs fully without them.
# ============================================================

# --- OpenAI (optional — enables AI-generated narrative summaries) ---
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (optional — alternative to OpenAI for summaries) ---
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- NewsAPI.org (optional — adds extra article coverage) ---
# Free tier: 100 requests/day. Get a key at: https://newsapi.org/register
NEWSAPI_KEY=

# --- Application settings ---
MAX_ARTICLES=200
FETCH_TIMEOUT=15
CACHE_TTL_MINUTES=30
DEFAULT_LOOKBACK_DAYS=7

# --- LLM behaviour ---
# "auto" = use LLM only if a key is present
# "true" = always try LLM (fails gracefully if no key)
# "false" = never use LLM, even if a key is present
USE_LLM=auto
